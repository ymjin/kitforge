{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // Web-API package (Request/Response/FormData/fetch via the DOM lib). Exclude
    // ambient @types (e.g. @types/node) so Node globals don't shadow DOM types.
    "types": []
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
