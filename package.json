{
  "name": "kitforge",
  "version": "0.0.0",
  "private": true,
  "description": "Personal reusable kit — design tokens, UI widgets, and auth wrappers.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=18"
  }
}
